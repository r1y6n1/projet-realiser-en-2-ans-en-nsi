import random 

from consts import CLASSES
from utils import verifier_structure, tirageDe, verifier_evenement

class Personnage:
    """
    Classe représentant un personnage dans le RPG.

    Attributes:
        __classe: La classe du personnage (Guerrier, Sorcier, etc.).
        __nom: Le nom du personnage.
        __vie: Les points de vie actuels du personnage.
        __degats_physiques_proches: Les dégâts physiques infligés à courte portée.
        __degats_physiques_loin: Les dégâts physiques infligés à longue portée.
        __degats_magiques_loin: Les dégâts magiques infligés à longue portée.
        __points_soin: Les points de soin disponibles pour guérir.
        __potion_soin: Le nombre de breuvages de soin disponibles.
        __points_vie_max: Le maximum de points de vie que le personnage peut avoir.
        __chance: Le pourcentage de chance pour une action du personnage.
        __chance_critique: Le pourcentage de chance de réaliser un coup critique.
        __vitesse_attaque: La vitesse à laquelle le personnage peut attaquer.
        __description: description du personnage. # ajout pour l'introduction des personnages
        
    Methods:
        __init__(classe, nom, stats): Initialise un personnage avec sa classe, nom et statistiques.
        get_classe(): Renvoie la classe du personnage.
        get_nom(): Renvoie le nom du personnage.
        get_vie(): Renvoie les points de vie actuels du personnage.
        set_vie(vie): Met à jour les points de vie du personnage.
        est_vivant(): Vérifie si le personnage est encore en vie.
        pourcentageVie(): Renvoie le pourcentage de vie actuelle par rapport à la vie maximale.
        aChance(): Vérifie si le personnage a une chance pour une action.
        presentation(): Affiche une introduction du personnage.
        afficher_stats(detailled=False): Affiche les statistiques du personnage.
        ajoutVie(valeur): Ajoute des points de vie au personnage.
        retraitVie(valeur): Retire des points de vie au personnage.
        soin(): Soigne le personnage en fonction de sa chance.
        attaque(autre_joueur): Simule une attaque contre un autre personnage.

    """
    def __init__(self, classe, nom, stats, description=""):
        """
        Initialise un personnage avec sa classe, nom et statistiques.

        :param classe: La classe du personnage.
        :type classe: str
        :param nom: Le nom du personnage.
        :type nom: str
        :param stats: Un dictionnaire contenant les statistiques du personnage.
        :type stats: dict
        :raises AssertionError: Si la classe ou les statistiques sont invalides.
        """
        assert type(classe) == str and classe in CLASSES, 'classe inconnue'
        assert type(nom) == str, 'doit etre str'
        assert verifier_structure(stats), 'stats pas valides'
        self.__classe = classe
        self.__nom = nom
        self.__points_vie_max = stats["Max_life_points"]
        self.__vie = self.__points_vie_max # on demarre avec le max de points de vie
        self.__degats_physiques_proches = stats["Physical_near_damage"]
        self.__degats_physiques_loin = stats["Physical_far_damage"]
        self.__degats_magiques_loin = stats["Magical_far_damage"]
        self.__points_soin = stats["Heal_points"]
        self.__potion_soin = stats["Heal_potion"]
        self.__chance = stats["Luck"]
        self.__chance_critique = stats["Critical_chance"]
        self.__vitesse_attaque = stats["Attack_speed"]
        self.__description = description # ajout pour l'introduction des personnages

-Ce code initialise un personnage en vérifiant ses informations et en stockant ses statistiques et caractéristiques principales comme la classe, le nom, les points de vie et les dégâts.

(stats[“...”] mets au max de points vie,santé et autre)

    
    def get_classe(self):
        """
        Renvoie la classe du personnage.
        
        :returns: La classe du personnage.
        :rtype: str
        """
        return self.__classe
    
    def get_nom(self):
        """
        Renvoie le nom du personnage.

        :returns: Le nom du personnage.
        :rtype: str
        """
        return self.__nom

    def get_vie(self):
        """
        Renvoie les points de vie actuels du personnage.

        :returns: Les points de vie actuels du personnage.
        :rtype: int
        """
        return self.__vie

    def get_degats_physiques_proches(self):
        """
        Renvoie les dégâts physiques de proximité du personnage.

        :returns: Les dégâts physiques de proximité.
        :rtype: int
        """
        return self.__degats_physiques_proches
        
    def get_degats_physiques_loin(self):
        """
        Renvoie les dégâts physiques à distance du personnage.

        :returns: Les dégâts physiques à distance.
        :rtype: int
        """
        return self.__degats_physiques_loin

    def get_degats_magiques_loin(self):
        """
        Renvoie les dégâts magiques à distance du personnage.

        :returns: Les dégâts magiques à distance.
        :rtype: int
        """
        return self.__degats_magiques_loin

    def get_points_soin(self):
        """
        Renvoie les points de soin du personnage.

        :returns: Les points de soin du personnage.
        :rtype: int
        """
        return self.__points_soin

    def get_breuvage_soin(self):
        """
        Renvoie le nombre de breuvages de soin du personnage.

        :returns: Le nombre de breuvages de soin du personnage.
        :rtype: int
        """
        return self.__potion_soin

    def get_points_vie_max(self):
        """
        Renvoie le nombre de points de vie maximum du personnage.

        :returns: Le nombre de points de vie maximum du personnage.
        :rtype: int
        """
        return self.__points_vie_max
        
    def get_chance(self):
        """
        Renvoie le pourcentage de chance pour une action du personnage.

        :returns: Le pourcentage de chance pour une action du personnage.
        :rtype: int
        """
        return self.__chance

    def get_chance_critique(self):
        """
        Renvoie le pourcentage de chance de réaliser un coup critique du personnage.

        :returns: Le pourcentage de chance de coup critique du personnage.
        :rtype: int
        """
        return self.__chance_critique

    def get_vitesse_attaque(self):
        """
        Renvoie la vitesse d'attaque du personnage.

        :returns: La vitesse d'attaque du personnage.
        :rtype: int
        """
        return self.__vitesse_attaque

    def set_vie(self, vie):
        """
        Met à jour les points de vie du personnage.

        :param vie: Les nouveaux points de vie du personnage.
        :type vie: int
        :raises AssertionError: Si la valeur de vie n'est pas valide.
        """
        assert type(vie) == int and vie >= 0 and vie <= self.__points_vie_max, 'valeur vie invlide'
        self.__vie = vie
        
    def est_vivant(self):
        """
        Vérifie si le personnage est encore en vie.

        :returns: True si le personnage est vivant, False sinon.
        :rtype: bool
        """
        return self.__vie > 0

    def pourcentageVie(self):
        """
        Renvoie le pourcentage de vie actuelle par rapport à la vie maximale.

        :returns: Le pourcentage de vie actuelle.
        :rtype: float
        """
        return (self.__vie * 100)/self.__points_vie_max

    def aChance(self):
        """
        Vérifie si le personnage a une chance pour une action.

        :returns: True si le personnage a une chance, False sinon.
        :rtype: bool
        """
        de = tirageDe()
        return de <= self.__chance

    def presentation(self): 
        """
        Renvoie l’introduction narrative du personnage.
    
        :return: dialogue de présentation
        :rtype: str
        """
        # on a du ajouter l' attribut __description a l'init (comme dans LieuRPG)
        return self.__description

        
    def afficher_stats(self, detailled=False):
        """
        Affiche les statistiques du personnage.

        :param detailled: Active ou désactive l'affichage détaillé, defaults to False.
        :type detailled: bool, optional
        """
        assert type(detailled) == bool , 'type booleen attendu'
        if detailled == False:
            print (f"vie: {self.__vie}pts ({self.pourcentageVie():.2f}%), soin: {self.__points_soin}pts, chance: {self.__chance}")
        else:
            print(f"vie: {self.__vie}pts ({self.pourcentageVie():.2f}%))")
            print(f"classe: {self.__classe}")
            print(f"nom: {self.__nom}")
            print(f"pts vie max: {self.__points_vie_max}")
            print(f"degats physiques proches: {self.__degats_physiques_proches}")
            print(f"degats physiques loin: {self.__degats_physiques_loin}")
            print(f"degats magiques loin: {self.__degats_magiques_loin}")
            print(f"points soin: {self.__points_soin}")
            print(f"potion soin: {self.__potion_soin}")
            print(f"chance: {self.__chance}")
            print(f"chance critique: {self.__chance_critique}")
            print(f"vitesse attaque: {self.__vitesse_attaque}")

    def ajoutVie(self, valeur):
        """
        Ajoute des points de vie au personnage.

        :param valeur: La valeur à ajouter.
        :type valeur: int
        :raises AssertionError: Si la valeur n'est pas un nombre positif.
        """
        assert type(valeur) == int and valeur >= 0, 'valeur vie invlide'
        if self.__vie + valeur > self.__points_vie_max:
            self.__vie = self.__points_vie_max
        else:
            self.__vie += valeur

    def retraitVie(self, valeur):
        """
        Retire des points de vie au personnage.

        :param valeur: La valeur à retirer.
        :type valeur: int
        :raises AssertionError: Si la valeur n'est pas un nombre positif.
        """
        assert type(valeur) == int and valeur >= 0, 'valeur vie invlide'
        if self.__vie - valeur < 0:
            self.__vie = 0
        else:
            self.__vie -= valeur
            
    def soin(self, coef_lieu=1.0): # ajout du coef de lieu
        """
        Tente de soigner le personnage.
        
        Le soin utilise une potion spécifique à la classe du personnage.
        L'action peut échouer en fonction de la chance.
        
        Cette méthode ne gère aucun affichage.
        Elle retourne uniquement un résultat structuré décrivant l'action.
        
        :return: succès, données de soin
        :rtype: tuple[bool, dict]
        
        Structure du dictionnaire retourné :
        {
            "type": "attack" | "heal" | "death" | "text" | "end",
            "source": Personnage | None,
            "target": Personnage | None,
            "success": bool,
            "value": int,
            "damage_type": str | None,
            "potion": str | None,
            "message": str | None
        }
        """
        assert type(coef_lieu) == float, "le coef_lieu doit etre un float"
        
        succes = self.aChance()
        points = 0
        potion = None
        
        if succes and self.__vie < self.__points_vie_max: # pas vie au max
            points = int(self.__points_soin * coef_lieu) # on multiplie par le coef de lieu mais on veut un int
            potion = self.get_breuvage_soin()
            vie_avant = self.__vie
            self.ajoutVie(points)
            vie_apres = self.__vie
            points = vie_apres - vie_avant
    
        event = {
            "type": "heal",
            "source": self,
            "target": self,
            "success": succes,
            "value": points,
            "damage_type": None,
            "potion": potion,
            "message": None,
        }
        
        verifier_evenement(event, expected_type="heal")
        return (succes, event)

    
    def _calculer_degats(self):
        """
        Calcule les dégâts infligés et renvoie (degats, damage_type).
    
        :return: (degats, damage_type)
        :rtype: tuple[int, str]
        """
        # valeurs candidates (degats, type)
        candidats = [
            (self.__degats_physiques_proches, "physique_proche"),
            (self.__degats_physiques_loin, "physique_loin"),
            (self.__degats_magiques_loin, "magique_loin"),
        ]
    
        # on garde uniquement les dégâts strictement positifs
        candidats = [c for c in candidats if c[0] > 0]
        assert len(candidats) >= 1, "Le personnage doit avoir au moins un type de dégât > 0"
    
        degats, damage_type = random.choice(candidats)
    
        # critique éventuel x1.5
        assert isinstance(self.__chance_critique, int)
        if random.randint(1, 100) <= self.__chance_critique:
            degats = int(degats * 1.5)
    
        assert isinstance(degats, int) and degats >= 0
        assert isinstance(damage_type, str)
        return (degats, damage_type)

    def attaque(self, autre_joueur):
        """
        Tente une attaque contre un autre personnage.
         
        L'attaque peut infliger différents types de dégâts :
        - physique au corps à corps
        - physique à distance
        - magique à distance
         
        Cette méthode ne gère aucun affichage.
        Elle retourne uniquement un résultat structuré décrivant l'action.
         
        :param autre_joueur: cible de l'attaque
        :type autre_joueur: Personnage
        :return: événement d'attaque normalisé
        :rtype: dict
         
        Structure du dictionnaire retourné :
        {
            "action": "attack",
            "source": Personnage,
            "target": Personnage,
            "success": bool,
            "value": int,                # dégâts infligés (0 si échec)
            "damage_type": str           # "physique_proche" | "physique_distance" | "magique_distance"
        }
        """
        assert isinstance(autre_joueur, Personnage)
        assert autre_joueur is not self
        

        succes = self.aChance()
        degats = 0
        damage_type = None
    
        if succes:
            degats, damage_type = self._calculer_degats()
            vie_avant = autre_joueur.get_vie()
            autre_joueur.retraitVie(degats)
            vie_apres = autre_joueur.get_vie()
            degats = vie_avant - vie_apres
    
        event = {
            "type": "attack",
            "source": self,
            "target": autre_joueur,
            "success": succes,
            "value": degats,
            "damage_type": damage_type,
            "potion": None,
            "message": None,
        }
    
        verifier_evenement(event, expected_type="attack")
        return event



