        print(f"TirageDe a rendu {res}")
        assert type(res) == int and res >= 0 and res <= 100, 'tirageDe erreur'
        
    print("→ tirageDe OK\n")
    print("-" * 50 + "\n")

    print("=== TEST verifier_structure ===")
    from consts import CLASSES_DATA
