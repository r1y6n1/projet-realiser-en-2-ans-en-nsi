Description
-----------
Fonctions utilitaires du projet RPG POO.

Ce module regroupe des outils génériques utilisés par plusieurs parties
du programme, sans logique métier propre :

- tirages aléatoires simples
- vérifications de structures de données
- fonctions d'aide indépendantes des classes principales
""" 

import random

def tirageDe():
    """
        Simule le lancer de dé en retournant un entier aléatoire entre 0 et 100.

        :returns: Entier aléatoire entre 1 et 100.
        :rtype: int
    """
    return random.randint(1, 100) #ne doit pas etre 0

def verifier_structure(stats):
    """
        Vérifie la structure des statistiques d'un personnage.

        :param stats: Dictionnaire contenant les statistiques du personnage.
        :type stats: object
        :return: True si la structure est conforme, False sinon.
        :rtype: bool
    """
    if not isinstance(stats, dict):
        return False
    
    # clés obligatoires
    required_keys = {
        "Physical_near_damage",
        "Physical_far_damage",
        "Magical_far_damage",
        "Heal_points",
        "Heal_potion",
        "Max_life_points",
        "Luck",
        "Critical_chance",
        "Attack_speed",
    }

    if not required_keys.issubset(stats.keys()):
        return False
    
    #verif types stats
    if not (type(stats["Physical_near_damage"]) == int and stats["Physical_near_damage"] >= 0):
        return False
    if not (type(stats["Physical_far_damage"]) == int and stats["Physical_far_damage"] >= 0):
        return False
    if not (type(stats["Magical_far_damage"]) == int and stats["Magical_far_damage"] >= 0):
        return False
    if not (type(stats["Heal_points"]) == int and stats["Heal_points"] >= 0):
        return False
    if not (type(stats["Heal_potion"]) == str):
        return False
    if not (type(stats["Max_life_points"]) == int and stats["Max_life_points"] > 0):
        return False
    if not (type(stats["Luck"]) == int and stats["Luck"] >=0 and stats["Luck"] <= 100):
        return False
    if not (type(stats["Critical_chance"]) == int and stats["Critical_chance"] >= 0 and stats["Critical_chance"] <= 100):
        return False
    if not (type(stats["Attack_speed"]) == int and stats["Attack_speed"] >= 0):
        return False
    return True
    

def verifier_evenement(event, expected_type=None):
    """
    Vérifie qu'un événement respecte le contrat attendu du moteur RPG.

    :param event: événement à vérifier
    :type event: dict
    :param expected_type: type d'événement attendu ("attack", "heal", etc.)
    :type expected_type: str | None
    :raises AssertionError: si l'événement est invalide
    """
    assert isinstance(event, dict)

    # clés obligatoires
    required_keys = {
        "type",
        "source",
        "target",
        "success",
        "value",
        "damage_type",
        "potion",
        "message",
    }

    assert required_keys.issubset(event.keys())

    # type d'événement
    assert isinstance(event["type"], str)
    if expected_type is not None:
        assert event["type"] == expected_type

    # succès / valeur
    assert isinstance(event["success"], bool)
    assert isinstance(event["value"], int)
    assert event["value"] >= 0

    # champs optionnels typés
    assert event["damage_type"] is None or isinstance(event["damage_type"], str)
    assert event["potion"] is None or isinstance(event["potion"], str)
    assert event["message"] is None or isinstance(event["message"], str)

