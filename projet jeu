#code2 histoire

Description
-----------
Gestion du déroulement narratif et du combat.

La classe :class:`Histoire` orchestre le scénario sous forme d'événements
normalisés (moteur événementiel). Elle ne gère ni l'affichage (GUI),
ni la mise en forme du texte (narration), uniquement la logique de déroulement.

Contrat d'événement (socle)
---------------------------
Tout événement renvoyé par :meth:`Histoire.next_step` respecte a minima :

- ``type``: ``str`` ("text", "attack", "heal", "death", "end")
- ``source``: ``Personnage | None``
- ``target``: ``Personnage | None``
- ``success``: ``bool``
- ``value``: ``int`` (>= 0)
- ``damage_type``: ``str | None`` (attaque)
- ``potion``: ``str | None`` (soin)
- ``message``: ``str | None`` (texte neutre)

Extensions (acceptées)
----------------------
Selon le type, :class:`Histoire` peut *ajouter* des champs optionnels
sans casser le contrat (ex: ``dialogue``, ``coef``, ``full_life``).
"""

import random
from factory import creer_equipes
from utils import verifier_evenement
from consts import HEAL_LIFE_THRESHOLD, HEAL_ATTEMPT_PROBABILITY
from typing import Optional, Dict, Any
from narration import Narration
from personnage import Personnage
from lieu import LieuRPG


class Histoire:
    """
    Classe orchestrant le déroulement narratif et les combats du RPG.

    La classe Histoire joue le rôle de moteur événementiel :
    elle coordonne les personnages, le lieu et les phases du récit,
    et produit des événements normalisés consommables par
    une interface texte ou graphique.

    Elle ne gère aucun affichage et ne dépend d’aucune interface graphique.

    Attributes:
        personnages (list[Personnage]):
            Liste des personnages participant à l’histoire.
        lieu (LieuRPG):
            Lieu dans lequel se déroule le récit.
        groupe1 (list[Personnage]):
            Premier groupe de combat.
        groupe2 (list[Personnage]):
            Second groupe de combat.
        phase (str):
            Phase actuelle du scénario
            ("intro", "groupes", "combat", "fin", "done").
        idx_perso (int):
            Index utilisé pour l’introduction progressive des personnages.
        _combat_pairs (list[tuple[Personnage, Personnage]]):
            Liste des paires potentielles d’affrontement.
        _pair_i (int):
            Index de la paire de combat courante.
        _prepared_groups (bool):
            Indique si les groupes ont été initialisés.
        _mort_recente (bool):
            Indique si une mort vient de se produire
            (permet une réorganisation des combats).
        _g1i (int):
            Index d’annonce des personnages du groupe 1.
        _g2i (int):
            Index d’annonce des personnages du groupe 2.
        narration (Narration):
            objet narration

    Methods:
        __init__(personnages, lieu):
            Initialise l’histoire avec les personnages et le lieu.
        getPersonnages():
            Renvoie la liste des personnages de l’histoire.
        getGroupe1():
            Renvoie la liste des personnages du groupe 1.
        getGroupe2():
            Renvoie la liste des personnages du groupe 2.
        next_step():
            Avance le scénario d’une étape et renvoie un événement normalisé.
        run_textuel(narration):
            Exécute l’histoire en mode texte (debug / démonstration).

    Event system:
        La méthode next_step() renvoie des événements sous forme de dictionnaires
        respectant un contrat strict, validé par utils.verifier_evenement().

        Types d’événements possibles :
            - "text"   : narration ou description
            - "attack" : attaque entre deux personnages
            - "heal"   : tentative de soin
            - "death"  : mort d’un personnage
            - "end"    : fin du combat et annonce du vainqueur

    Design choices:
        - Séparation stricte logique / affichage
        - Architecture événementielle
        - Compatible interface texte et GUI
        - Pensée pour être testable et pédagogique (Terminale NSI)
    """
    def __init__(self, personnages, lieu):
        """
        Initialise l'histoire.

        :param personnages: personnages du récit
        :type personnages: list
        :param lieu: lieu du récit
        :type lieu: LieuRPG
        """
        assert isinstance(personnages, list)
        assert len(personnages) >= 2
        for p in personnages:
            assert isinstance(p, Personnage)
        assert isinstance(lieu, LieuRPG)
        
        self.personnages = personnages
        self.lieu = lieu
        self.groupe1 = None
        self.groupe2 = None
        
        self.phase = "intro"
        self.idx_perso = 0

        self._combat_pairs = []
        self._pair_i = 0
        self._prepared_groups = False
        self._mort_recente = False
        
        self._g1i = 0
        self._g2i = 0
        
        self.narration = Narration(color=False)
        
    # ========================================================
    # GETTERS
    # ========================================================
        
    def getPersonnages(self):
        """
        Retourne une copie de la liste des personnages de l'histoire.
    
        :return: liste des personnages
        :rtype: list<Personnage>
        """
        return self.personnages.copy()


    def getGroupe1(self):
        """
        Retourne une copie du premier groupe de personnages.
    
        :return: liste des personnages du groupe 1
        :rtype: list<Personnage>
        """
        return self.groupe1.copy()
    
    
    def getGroupe2(self):
        """
        Retourne une copie du second groupe de personnages.
    
        :return: liste des personnages du groupe 2
        :rtype: list<Personnage>
        """
        return self.groupe2.copy()


    # ========================================================
    # OUTILS INTERNES
    # ========================================================
    
    @staticmethod
    def _event_base(etype: str, source, target, success: bool, value: int, message: Optional[str] = None, damage_type: Optional[str] = None, potion: Optional[str] = None) -> Dict[str, Any]:
        """
        Construit un événement conforme au contrat (socle).

        :param etype: type d'événement
        :type etype: str
        :param source: acteur de l'action
        :type source: Personnage | None
        :param target: cible de l'action
        :type target: Personnage | None
        :param success: succès de l'action
        :type success: bool
        :param value: valeur (dégâts / soins), >= 0
        :type value: int
        :param message: message neutre (optionnel)
        :type message: str | None
        :param damage_type: type de dégâts (attaque)
        :type damage_type: str | None
        :param potion: potion/breuvage (soin)
        :type potion: str | None
        :return: événement conforme au contrat
        :rtype: dict
        """
        assert isinstance(etype, str) and etype != ""
        assert isinstance(success, bool)
        assert isinstance(value, int) and value >= 0
        assert damage_type is None or isinstance(damage_type, str)
        assert potion is None or isinstance(potion, str)
        assert message is None or isinstance(message, str)

        return {
            "type": etype,
            "source": source,
            "target": target,
            "success": success,
            "value": value,
            "damage_type": damage_type,
            "potion": potion,
            "message": message,
        }

    def _prepare_groups(self):
        """
        Prépare les groupes de combat.
         
        Sépare les personnages en deux groupes adverses
        et génère les paires de combats possibles.
         
        Initialise également l'ordre des affrontements.
        """
        
        # on ne fait des groupes qu'avec les personnages vivants
        personnages_vivants = []
        for p in self.personnages:
            if p.est_vivant():
                personnages_vivants.append(p)
        self.groupe1, self.groupe2 = creer_equipes(personnages_vivants)

        # index de parcours des groupes
        self._g1i = 0
        self._g2i = 0
    
        # paires de combat
        self._combat_pairs = []
        for p1 in self.personnages:
            adversaires = self.groupe2 if p1 in self.groupe1 else self.groupe1
            for p2 in adversaires:
                if p1 != p2:
                    self._combat_pairs.append((p1, p2))
    
        random.shuffle(self._combat_pairs)
    
        self._pair_i = 0
        self._prepared_groups = True

    def _combat_continue(self):
        """
        Indique si le combat peut continuer.
    
       :return: True si les deux groupes ont au moins un survivant
       :rtype: bool
       """
        g1 = False
        for p in self.groupe1:
            if p.est_vivant():
                g1 = True
                
        g2 = False
        for p in self.groupe2:
            if p.est_vivant():
                g2 = True
               
        return (g1 == True) and (g2 == True)
               
           

    # ========================================================
    # MOTEUR NARRATIF
    # ========================================================

    def next_step(self):
        """
        Avance l'histoire d'une étape.

        :return: événement narratif ou None
        :rtype: dict | None
        
        Structure d’un événement :

        event = {
            "type": "text" | "attack" | "heal" | "death" | "end",
            "source": Personnage | None,      # acteur de l’action
            "target": Personnage | None,      # cible de l’action
            "value": int | None,              # dégâts ou soins effectifs
            "success": bool | None,           # succès de l’action
            "message": str | None,            # texte narratif neutre
            "dialogue": str | None,
        
            # champs optionnels selon le type
            "damage_type": str | None,        # attaque : type de dégâts
            "potion": str | None,             # soin : breuvage utilisé
            "full_life": bool | None,         # soin inutile (PV max)
            "coef": float | None              # coefficient du lieu
        }
        Le moteur (Histoire) produit les événements.
        Les vues (texte / graphique) les consomment sans logique métier.
        """
        # =========================================================
        # INTRO
        # =========================================================
        if self.phase == "intro":
            self.phase = "intro_persos"
            event = self._event_base(
                "text",
                source=None,
                target=None,
                success=True,
                value=0,
                message="L'histoire commence…",
            )
            verifier_evenement(event, expected_type="text")
            return event

        if self.phase == "intro_persos":
            if self.idx_perso < len(self.personnages):
                p = self.personnages[self.idx_perso]
                self.idx_perso += 1
                event = self._event_base(
                    "text",
                    source=p,
                    target=None,
                    success=True,
                    value=0,
                    message=f"{p.get_classe()} — {p.get_nom()}: {p.presentation()}", # ajout de la description du personnage
                )
                verifier_evenement(event, expected_type="text")
                return event

            self.phase = "lieu"
            event = self._event_base(
                "text",
                source=None,
                target=None,
                success=True,
                value=0,
                message="Le décor se met en place…",
            )
            verifier_evenement(event, expected_type="text")
            return event

        # =========================================================
        # LIEU + MISE EN SCENE
        # =========================================================
        if self.phase == "lieu":
            self.phase = "mise_en_scene"
            event = self._event_base(
                "text",
                source=None,
                target=None,
                success=True,
                value=0,
                message=f"Les événements se déroulent à {self.lieu.get_nom()}.",
            )
            verifier_evenement(event, expected_type="text")
            return event

        if self.phase == "mise_en_scene":
            self.phase = "tension"
            event = self._event_base(
                "text",
                source=None,
                target=None,
                success=True,
                value=0,
                message=self.lieu.get_description(),
            )
            verifier_evenement(event, expected_type="text")
            return event

        if self.phase == "tension":
            self.phase = "groupes"
            event = self._event_base(
                "text",
                source=None,
                target=None,
                success=True,
                value=0,
                message="Une dispute éclate. Les groupes se forment.",
            )
            verifier_evenement(event, expected_type="text")
            return event

        # =========================================================
        # GROUPES (annonce progressive)
        # =========================================================
        if self.phase == "groupes":
            if not self._prepared_groups:
                self._prepare_groups()
                event = self._event_base(
                    "text",
                    source=None,
                    target=None,
                    success=True,
                    value=0,
                    message="Deux camps distincts émergent.",
                )
                verifier_evenement(event, expected_type="text")
                return event

            if self._g1i < len(self.groupe1):
                p = self.groupe1[self._g1i]
                self._g1i += 1
                event = self._event_base(
                    "text",
                    source=p,
                    target=None,
                    success=True,
                    value=0,
                    message=f"{p.get_nom()} rejoint le groupe 1.",
                )
                verifier_evenement(event, expected_type="text")
                return event

            if self._g2i < len(self.groupe2):
                p = self.groupe2[self._g2i]
                self._g2i += 1
                event = self._event_base(
                    "text",
                    source=p,
                    target=None,
                    success=True,
                    value=0,
                    message=f"{p.get_nom()} rejoint le groupe 2.",
                )
                verifier_evenement(event, expected_type="text")
                return event

            self.phase = "combat"
            event = self._event_base(
                "text",
                source=None,
                target=None,
                success=True,
                value=0,
                message="Le combat commence.",
            )
            verifier_evenement(event, expected_type="text")
            return event

        # =========================================================
        # COMBAT
        # =========================================================
        if self.phase == "combat":

            if not self._combat_continue():
                self.phase = "fin"
                event = self._event_base(
                    "text",
                    source=None,
                    target=None,
                    success=True,
                    value=0,
                    message="",
                )
                verifier_evenement(event, expected_type="text")
                return event

            if self._mort_recente:
                self._prepare_groups()
                self._mort_recente = False
                event = self._event_base(
                    "text",
                    source=None,
                    target=None,
                    success=True,
                    value=0,
                    message="La mêlée se réorganise, les adversaires changent.",
                )
                verifier_evenement(event, expected_type="text")
                return event

            if self._pair_i >= len(self._combat_pairs):
                self._prepare_groups()
                return self.next_step()

            acteur, cible = self._combat_pairs[self._pair_i]
            self._pair_i += 1

            if not (acteur.est_vivant() and cible.est_vivant()):
                return self.next_step()

            opposants = (
                (acteur in self.groupe1 and cible in self.groupe2)
                or (acteur in self.groupe2 and cible in self.groupe1)
            )
            if not opposants:
                return self.next_step()

            # ---------- SOIN ----------
            if (
                acteur.get_vie() < HEAL_LIFE_THRESHOLD * acteur.get_points_vie_max()
                and random.random() < HEAL_ATTEMPT_PROBABILITY
            ):
                coef_lieu = self.lieu.get_heal_modifier(acteur.get_classe()) # on utlise le coef de lieu dans la methode soin
                (succes, event) = acteur.soin(coef_lieu)  # attention soin retourne un tuple et pas juste un event !!

                # extensions
                event["full_life"] = acteur.get_vie() == acteur.get_points_vie_max()
                event["coef"] = coef_lieu
                event["dialogue"] = (
                    self.narration.heal_success(acteur.get_classe())
                    if event["success"] and event["value"] > 0
                    else self.narration.heal_failure(acteur.get_classe())
                )

                # message factuel (pour suivi élève)
                if event["success"]:
                    event["message"] = (
                        f"{acteur.get_nom()} se soigne et récupère {event['value']} PV."
                    )
                else:
                    event["message"] = (
                        f"{acteur.get_nom()} tente de se soigner mais échoue."
                    )
    
                verifier_evenement(event, expected_type="heal")
                return event

            # ---------- ATTAQUE ----------
            event = acteur.attaque(cible)

            # message factuel
            if event["success"]:
                event["message"] = (
                    f"{acteur.get_nom()} attaque {cible.get_nom()} "
                    f"et inflige {event['value']} dégâts ({event['damage_type']})."
                )
            else:
                event["message"] = (
                    f"{acteur.get_nom()} attaque {cible.get_nom()} mais échoue."
                )

            # extensions
            event["coef"] = self.lieu.get_attack_modifier(acteur.get_classe())
            event["dialogue"] = self.narration.attack_success(acteur.get_classe(), cible.get_classe()) if event["success"] else self.narration.attack_failure(acteur.get_classe(), cible.get_classe())

            verifier_evenement(event, expected_type="attack")

            if not cible.est_vivant():
                self._mort_recente = True
                death = self._event_base(
                    "death",
                    source=acteur,
                    target=cible,
                    success=True,
                    value=0,
                    message=f"{cible.get_nom()} tombe au sol. La foule s'agite.",
                )
                verifier_evenement(death, expected_type="death")
                return death

            return event

        # =========================================================
        # FIN
        # =========================================================
        if self.phase == "fin":
            self.phase = "done"
            gagnant = (
                "Le groupe 1 sort vainqueur."
                if any(p.est_vivant() for p in self.groupe1)
                else "Le groupe 2 sort vainqueur."
            )
            event = self._event_base(
                "end",
                source=None,
                target=None,
                success=True,
                value=0,
                message=gagnant,
            )
            verifier_evenement(event, expected_type="end")
            return event

        # =========================================================
        # TERMINE
        # =========================================================
        return None

    # ========================================================
    # RUNNER TEXTE (POUR TESTS)
    # ========================================================

    def run_textuel(self, narration):
        """
        Exécute l'histoire en mode texte en consommant les événements produits
        par la méthode next_step().
    
        Cette méthode illustre le fonctionnement du moteur événementiel :
        elle récupère successivement des événements normalisés et les interprète
        pour produire une narration textuelle.
    
        Aucun affichage graphique n’est effectué ici.
    
        :param narration: objet responsable de la génération de dialogues
        :type narration: Narration
        """
        event = self.next_step()
    
        while event is not None and event.get("type") != "end":
            verifier_evenement(event)
            etype = event["type"]
    
            # --- MESSAGE FACTUEL (toujours affiché s'il existe) ---
            msg = event.get("message")
            if isinstance(msg, str):
                print(msg)
    
            # --- DIALOGUES OPTIONNELS (Narration) ---
            if etype == "attack":
                src = event["source"]
                tgt = event["target"]
                dmg = event["value"]
    
                if src and tgt:
                    if dmg > 0:
                        print(src.get_nom()+': "',
                            narration.attack_success(
                                src.get_classe(),
                                tgt.get_classe()
                            )+'"'
                        )
                    else:
                        print(src.get_nom()+': "',
                            narration.attack_failure(
                                src.get_classe(),
                                tgt.get_classe()
                            )+'"'
                        )
    
            elif etype == "heal":
                src = event["source"]
                pts = event["value"]
    
                if src:
                    if pts > 0:
                        print(src.get_nom()+': "',
                            narration.heal_success(
                                src.get_classe()
                            )+'"'
                        )
                    else:
                        print(src.get_nom()+': "',
                            narration.heal_failure(
                                src.get_classe()
                            )+'"'
                        )
    
            event = self.next_step()
    
        # --- fin explicite ---
        if event is not None:
            verifier_evenement(event, expected_type="end")
            msg = event.get("message")
            if isinstance(msg, str):
                print(msg)



# ============================================================
# TEST MANUEL
# ============================================================
if __name__ == "__main__":
    from factory import creer_personnages, creer_lieu

    histoire = Histoire(
        creer_personnages(),
        creer_lieu("Taverne")
    )

    narration = Narration(color=True)
    histoire.run_textuel(narration)

