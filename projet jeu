        "Luck": 45,
        "Critical_chance": 40,
        "Attack_speed": 5,
    }
    
    print("test verif structure avec mauvaise clef")
    assert not verifier_structure(mauvaise_clef)
    
    mauvais_type = {
        "Physical_near_damage": 10, 
        "Physical_far_damage": 50,
