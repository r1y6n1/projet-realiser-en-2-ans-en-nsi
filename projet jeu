#code6 narration


Description
-----------
Moteur de narration du projet RPG POO.

Ce module transforme les données narratives (messages.py)
en textes exploitables par :
- la console (avec couleurs)
- l’interface graphique (sans couleurs)

Aucune logique métier.
"""

import random

from consts import COULEURS_CLASSES, ENDC
import messages


class Narration:
    """
    Gestionnaire de narration du RPG.

    Cette classe génère des textes narratifs à partir des données
    définies dans ``messages.py``.

    Elle ne contient aucune logique métier et ne manipule aucun objet
    du jeu (Personnage, Lieu, Combat, etc.).

    Attributes:
        color (bool): Active ou désactive la coloration console (ANSI).

    Methods:
        __init__(color): Initialise le moteur de narration.
        description_personnage(classe): Retourne une description d’un personnage.
        description_lieu(type_lieu): Retourne une description d’un lieu.
        heal_success(classe): Retourne un dialogue de soin réussi.
        heal_failure(classe): Retourne un dialogue de soin échoué.
        attack_success(classe, classe_adverse): Retourne un dialogue d’attaque réussie.
        attack_failure(classe, classe_adverse): Retourne un dialogue d’attaque échouée.
    """

    def __init__(self, color=True):
        """
        Initialise le moteur de narration.
    
        :param color: active ou non la coloration console
        :type color: bool
        :raises AssertionError: si ``color`` n'est pas un booléen
        """
        assert isinstance(color, bool), "color doit être un booléen"
        self.color = color

    # ========================================================
    # MÉTHODES INTERNES
    # ========================================================

    def _colorize(self, classe, texte):
        """
        Applique la couleur associée à une classe si la coloration est activée.
    
        :param classe: classe du personnage
        :type classe: str
        :param texte: texte narratif brut
        :type texte: str
        :return: texte éventuellement coloré
        :rtype: str
        :raises AssertionError: si les paramètres ne sont pas des chaînes
        """
        assert isinstance(classe, str), "classe doit être une str"
        assert isinstance(texte, str), "texte doit être une str"

        if not self.color:
            return texte

        if classe in COULEURS_CLASSES:
            return f"{COULEURS_CLASSES[classe]}{texte}{ENDC}"

        return texte

    # ========================================================
    # DESCRIPTIONS
    # ========================================================

    def description_personnage(self, classe):
        """
        Retourne une description narrative aléatoire d’un personnage.
    
        :param classe: classe du personnage
        :type classe: str
        :return: description narrative
        :rtype: str
        :raises AssertionError: si la classe est inconnue
        """
        assert isinstance(classe, str), "classe doit être une str"
        assert classe in messages.DESCRIPTIONS_PERSONNAGES, (
            f"Classe inconnue : {classe}"
        )

        return random.choice(messages.DESCRIPTIONS_PERSONNAGES[classe])

    def description_lieu(self, type_lieu):
        """
        Retourne une description narrative aléatoire d’un lieu.
    
        :param type_lieu: type du lieu
        :type type_lieu: str
        :return: description narrative
        :rtype: str
        :raises AssertionError: si le lieu est inconnu
        """
        assert isinstance(type_lieu, str), "type_lieu doit être une str"
        assert type_lieu in messages.DESCRIPTIONS_LIEUX, (
            f"Lieu inconnu : {type_lieu}"
        )

        descriptions = messages.DESCRIPTIONS_LIEUX[type_lieu]["descriptions"]
        assert isinstance(descriptions, list), "descriptions doit être une liste"
        assert len(descriptions) > 0, "liste de descriptions vide"

        return random.choice(descriptions)

    # ========================================================
    # SOINS
    # ========================================================

    def heal_success(self, classe):
        """
        Retourne un dialogue de soin réussi.
    
        :param classe: classe du personnage
        :type classe: str
        :return: dialogue narratif
        :rtype: str
        :raises AssertionError: si la classe est inconnue
        """
        assert isinstance(classe, str), "classe doit être une str"
        assert classe in messages.DIALOGUES_HEAL_SUCCESS, (
            f"Classe inconnue : {classe}"
        )

        texte = random.choice(messages.DIALOGUES_HEAL_SUCCESS[classe])
        return self._colorize(classe, texte)

    def heal_failure(self, classe):
        """
        Retourne un dialogue de soin échoué.
    
        :param classe: classe du personnage
        :type classe: str
        :return: dialogue narratif
        :rtype: str
        :raises AssertionError: si la classe est inconnue
        """
        assert isinstance(classe, str), "classe doit être une str"
        assert classe in messages.DIALOGUES_HEAL_FAILURE, (
            f"Classe inconnue : {classe}"
        )

        texte = random.choice(messages.DIALOGUES_HEAL_FAILURE[classe])
        return self._colorize(classe, texte)

    # ========================================================
    # ATTAQUES
    # ========================================================

    def attack_success(self, classe, classe_adverse):
        """
        Retourne un dialogue d’attaque réussie.
    
        :param classe: classe de l’attaquant
        :type classe: str
        :param classe_adverse: classe de la cible
        :type classe_adverse: str
        :return: dialogue narratif
        :rtype: str
        :raises AssertionError: si une classe est inconnue
        """
        assert isinstance(classe, str)
        assert isinstance(classe_adverse, str)
        assert classe in messages.DIALOGUES_ATTACK_SUCCESS
        assert classe_adverse in messages.DIALOGUES_ATTACK_SUCCESS[classe]

        texte = random.choice(
            messages.DIALOGUES_ATTACK_SUCCESS[classe][classe_adverse]
        )
        return self._colorize(classe, texte)

    def attack_failure(self, classe, classe_adverse):
        """
        Retourne un dialogue d’attaque échouée.
    
        :param classe: classe de l’attaquant
        :type classe: str
        :param classe_adverse: classe de la cible
        :type classe_adverse: str
        :return: dialogue narratif
        :rtype: str
        :raises AssertionError: si une classe est inconnue
        """
        assert isinstance(classe, str)
        assert isinstance(classe_adverse, str)
        assert classe in messages.DIALOGUES_ATTACK_FAILURE
        assert classe_adverse in messages.DIALOGUES_ATTACK_FAILURE[classe]

        texte = random.choice(
            messages.DIALOGUES_ATTACK_FAILURE[classe][classe_adverse]
        )
        return self._colorize(classe, texte)


# ============================================================
# TESTS
# ============================================================

if __name__ == "__main__":

    narration_color = Narration(color=True)
    narration_nocolor = Narration(color=False)

    print("\n=== TEST DESCRIPTIONS PERSONNAGES ===\n")
    for classe in messages.DESCRIPTIONS_PERSONNAGES:
        print(f"[{classe}]")
        print(narration_nocolor.description_personnage(classe))
        print()

    print("\n=== TEST DESCRIPTIONS LIEUX ===\n")
    for lieu in messages.DESCRIPTIONS_LIEUX:
        print(f"[{lieu}]")
        print(narration_nocolor.description_lieu(lieu))
        print()

    print("\n=== TEST HEAL SUCCESS / FAILURE ===\n")
    for classe in messages.DIALOGUES_HEAL_SUCCESS:
        print(f"[{classe}] SUCCESS :")
        print(narration_color.heal_success(classe))
        print(f"[{classe}] FAILURE :")
        print(narration_color.heal_failure(classe))
        print()

    print("\n=== TEST ATTACK SUCCESS / FAILURE ===\n")
    for classe in messages.DIALOGUES_ATTACK_SUCCESS:
        for cible in messages.DIALOGUES_ATTACK_SUCCESS[classe]:
            print(f"[{classe} → {cible}] SUCCESS :")
            print(narration_color.attack_success(classe, cible))
            print(f"[{classe} → {cible}] FAILURE :")
            print(narration_color.attack_failure(classe, cible))
            print()

    print("\n=== FIN DES TESTS NARRATION ===")

