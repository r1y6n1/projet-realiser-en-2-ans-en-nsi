Classe représentant un lieu du RPG.

Un lieu :
- possède un type, un nom et une description narrative
- influence le combat via des modificateurs d’attaque et de soin
- ne contient aucune logique de combat ou de narration
"""

from consts import MODIFICATEURS_LIEUX, LIEUX, CLASSES


class LieuRPG:
    """
    Représente un lieu du jeu.

    Attributs
    ----------
    _type_lieu : str
        Type du lieu (Taverne, Desert, Caverne)
    _nom : str
        Nom du lieu
    _description : str
        Description narrative du lieu
    """

    def __init__(self, type_lieu, nom, description):
        """
        Initialise un lieu.

        :param type_lieu: type du lieu
        :type type_lieu: str
        :param nom: nom du lieu
        :type nom: str
        :param description: description narrative
        :type description: str
        """
        assert type(type_lieu) == str and type_lieu in LIEUX, 'lieu inconnu'
        assert type(nom) == str, 'doit etre str'
        # bizarre : les descriptions dans messages sont sous forme de tuples...?
        for s in description:
            assert type(s) == str, "doit etre du texte"
        self._description = "".join(description)
        self._type_lieu = type_lieu
        self._nom = nom
        self.modificateurs = MODIFICATEURS_LIEUX[self._type_lieu]

    # ========================================================
    # GETTERS
    # ========================================================

    def get_nom(self):
        """
        Renvoie le nom du lieu.

        :return: nom du lieu
        :rtype: str
        """
        return self._nom


    def get_type(self):
        """
        Renvoie le type du lieu.

        :return: type du lieu
        :rtype: str
        """
        return self._type_lieu

    def get_description(self):
        """
        Renvoie la description narrative du lieu.

        :return: description du lieu
        :rtype: str
        """
        return self._description

    # ========================================================
    # MODIFICATEURS DE COMBAT
    # ========================================================

    def get_attack_modifier(self, classe):
        """
        Renvoie le coefficient de modification des attaques
        selon le lieu et la classe.

        :param classe: classe du personnage
        :type classe: str
        :return: coefficient multiplicatif
        :rtype: float
        """
        assert type(classe) == str and classe in CLASSES, 'classe inconnue'
        return self.modificateurs["attack"][classe]
        

    def get_heal_modifier(self, classe):
        """
        Renvoie le coefficient de modification des soins
        selon le lieu et la classe.

        :param classe: classe du personnage
        :type classe: str
        :return: coefficient multiplicatif
        :rtype: float
        """
        assert type(classe) == str and classe in CLASSES, 'classe inconnue'
        return self.modificateurs["heal"][classe]


# ============================================================
# TESTS
# ============================================================
if __name__ == "__main__":
    
    print("=== TEST LIEU ===\n")
    
    classe = "Elfe"
    for type_lieu in ["Taverne", "Desert", "Caverne"]:
        print(f"test de lieu de type {type_lieu}")
        lieu = LieuRPG(type_lieu, f"le nom de {type_lieu}", f"description de {type_lieu}")

        print(f"Nom : {lieu.get_nom()}")
        print(f"Description: {lieu.get_description()}")
        print(f"attack modificateur: {lieu.get_attack_modifier(classe)}")
        assert lieu.get_attack_modifier(classe) == MODIFICATEURS_LIEUX[type_lieu]['attack'][classe]
        print(f"heal modificateur: {lieu.get_heal_modifier(classe)}")
        assert lieu.get_heal_modifier(classe) == MODIFICATEURS_LIEUX[type_lieu]['heal'][classe]
        print()

    print("-" * 50 + "\n")

    print("Tests LieuRPG OK")



